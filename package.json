{
  "name": "enody",
  "version": "0.1.0",
  "description": "JavaScript SDK for Enody spectrally tunable lighting devices and EP01 firmware updates.",
  "type": "module",
  "main": "./src/node/index.js",
  "module": "./src/browser/index.js",
  "exports": {
    ".": {
      "browser": "./src/browser/index.js",
      "node": "./src/node/index.js",
      "default": "./src/browser/index.js"
    },
    "./data": "./src/data.js",
    "./optimize": "./src/optimize.js",
    "./update": {
      "browser": "./src/browser/update-entry.js",
      "node": "./src/node/update-entry.js",
      "default": "./src/browser/update-entry.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./src/browser/index.js",
    "./src/node/index.js",
    "./src/browser/update-entry.js",
    "./src/node/update-entry.js"
  ],
  "scripts": {
    "test": "node test/codec.test.js && node test/reference.test.js && node test/interface.test.js && node test/optimizer.test.js",
    "test:hil": "node test/hil.test.js"
  },
  "keywords": [
    "enody",
    "lighting",
    "spectral",
    "webserial",
    "esp32",
    "firmware"
  ],
  "license": "MIT",
  "dependencies": {
    "serialport": "^13.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/enodylighting/enody-js.git"
  },
  "homepage": "https://github.com/enodylighting/enody-js",
  "bugs": {
    "url": "https://github.com/enodylighting/enody-js/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
